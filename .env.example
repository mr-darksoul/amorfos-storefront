# ──────────────────────────────────────────────────────────────
# Amorfos — environment variables
# Copy this file to .env.local and fill in your Razorpay keys.
# ──────────────────────────────────────────────────────────────

# Razorpay TEST keys (https://dashboard.razorpay.com/app/keys)
# The publishable key id is also exposed to the browser to open the modal.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Public site URL (used for canonical tags, sitemap, OG metadata)
NEXT_PUBLIC_SITE_URL=https://amorfos.in

# When ready to go live, replace the three keys above with your
# live credentials (rzp_live_...). Keep KEY_SECRET server-side only.

# ── Supabase (https://supabase.com/dashboard → Project → Settings → API) ──
# Used for order history, customer tracking, and dynamic product management.
# Run supabase/schema.sql once in the Supabase SQL Editor to create tables.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin panel password (set any strong password you like)
ADMIN_PASSWORD=changeme

# ── Shiprocket (https://app.shiprocket.in → Settings → API) ───────────────
# Required for automated order syncing, AWB generation, and customer tracking.
SHIPROCKET_EMAIL=your_shiprocket_account_email
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_CHANNEL_ID=123456              # Settings → Channels → channel ID
SHIPROCKET_PICKUP_LOCATION=Primary        # Settings → Manage Warehouses → location name
SHIPROCKET_WEBHOOK_TOKEN=your_webhook_secret   # any random string; set same in Shiprocket webhook config
# Shiprocket webhook config (Settings → Additional Settings → Webhooks):
#   URL: https://<your-domain>/api/webhooks/delivery-status   (avoid "shiprocket"/"sr"/"kr" in the path — Shiprocket blocks those)
#   Auth Token Type: x-api-key   ·   Token: same value as SHIPROCKET_WEBHOOK_TOKEN

# ── Email via SMTP (GoDaddy mailbox) — transactional email ────────────────
# GoDaddy Professional Email: host smtpout.secureserver.net, port 465 (SSL).
# GoDaddy-hosted Microsoft 365: host smtp.office365.com, port 587 (STARTTLS).
# SMTP_USER/PASS are your care@amorfos.in login (use an app password if 2FA is on).
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=care@amorfos.in
SMTP_PASS=your_mailbox_password
SMTP_FROM=Amorfos <care@amorfos.in>

# ── WhatsApp Cloud API (Meta Business Suite) ───────────────────────────────
# Requires a verified Meta Business account and approved message templates.
# Templates to create: amorfos_order_confirmed, amorfos_shipping_update,
# amorfos_cart_reminder (abandoned-cart recovery — see below).
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123
WHATSAPP_ORDER_TEMPLATE_NAME=amorfos_order_confirmed
WHATSAPP_SHIPPING_TEMPLATE_NAME=amorfos_shipping_update
# Abandoned-cart recovery template. Approve a 3-parameter body in Meta, e.g.:
#   "Hi {{1}}, your {{2}} is still reserved at Amorfos. Complete your order
#    here: {{3}}. Questions? Just reply to this message."
# Params sent: {{1}} first name · {{2}} cart summary · {{3}} recovery link.
# Leave unset to skip the WhatsApp nudge (email recovery still sends via SMTP).
WHATSAPP_ABANDONED_TEMPLATE_NAME=amorfos_cart_reminder

# ── Analytics & ad pixels ──────────────────────────────────────────────────
# All optional: each tag only loads when its id is set. Without these, ads
# cannot measure conversions, retarget, or build lookalikes.
# GA4 measurement id (Google Analytics → Admin → Data Streams).
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Google Ads conversion id + the purchase conversion action's label.
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=xxxxxxxxxxxxxxxxxx
# Meta Pixel id (Events Manager). Used by the browser pixel AND server CAPI.
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456
# Meta Conversions API access token (Events Manager → Settings → Generate).
# Enables the reliable server-side Purchase event, de-duped with the pixel.
META_CAPI_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: while testing CAPI, paste the Events Manager test code here.
# META_TEST_EVENT_CODE=TEST12345
